# Root folder to scan (absolute path). You can change this at runtime in Settings.
SCAN_ROOT=/path/to/your/library
# Optional: LM Studio (or OpenAI-compatible) HTTP endpoint
LMSTUDIO_API_BASE=http://localhost:1234/v1
LMSTUDIO_MODEL=lmstudio-community/gemma-3-1b-it-GGUF
# If LM Studio requires an API key (usually not), set it here
LMSTUDIO_API_KEY=
# Enable/disable PDF text extraction during scan (can slow down)
EXTRACT_TEXT=true
# Limit in characters per document to send to LLM for metadata extraction
LLM_TEXT_LIMIT=20000

# Offline audio transcription
TRANSCRIBE_ENABLED=true
TRANSCRIBE_BACKEND=faster-whisper
# Для faster-whisper вместо пути можно указать имя (например, small, medium, large-v3)
TRANSCRIBE_MODEL_PATH=small
FASTER_WHISPER_CACHE_DIR=./models/faster-whisper
TRANSCRIBE_LANGUAGE=ru
